# AI Provider Configurations\nAI_PROVIDER_1_API_KEY=<Your AI Provider 1 API Key>\nAI_PROVIDER_1_SECRET=<Your AI Provider 1 Secret>\nAI_PROVIDER_1_ENDPOINT=<Your AI Provider 1 Endpoint>\n\nAI_PROVIDER_2_API_KEY=<Your AI Provider 2 API Key>\nAI_PROVIDER_2_SECRET=<Your AI Provider 2 Secret>\nAI_PROVIDER_2_ENDPOINT=<Your AI Provider 2 Endpoint>\n\n# GitHub Integration\nGITHUB_TOKEN=<Your GitHub Personal Access Token>\nGITHUB_REPO=<Your GitHub Repository>\nGITHUB_WEBHOOK_SECRET=<Your GitHub Webhook Secret>\n\n# Database Settings\nDB_HOST=<Your Database Host>\nDB_PORT=<Your Database Port>\nDB_USERNAME=<Your Database Username>\nDB_PASSWORD=<Your Database Password>\nDB_NAME=<Your Database Name>\n\n# Other Configuration Options\nLOG_LEVEL=info\nCACHE_ENABLED=true