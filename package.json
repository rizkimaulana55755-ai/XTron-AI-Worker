{
  "name": "xtron-ai-worker",
  "version": "1.0.0",
  "description": "XTron - AI Worker Platform untuk membuat aplikasi native ril dengan ribuan file dan milyaran kode",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "tsc",
    "test": "jest",
    "frontend:dev": "cd frontend && npm run dev",
    "backend:dev": "nodemon src/server.js",
    "fullstack:dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "axios": "^1.6.0",
    "firebase-admin": "^12.0.0",
    "google-auth-library": "^9.0.0",
    "octokit": "^3.1.0",
    "openai": "^4.28.0",
    "mongoose": "^8.0.0",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.1.0",
    "express-ratelimit": "^7.1.5",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "jest": "^29.7.0",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}